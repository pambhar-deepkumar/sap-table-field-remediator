{
  "global": {
    "files": "/src/**/*.*"
  },
  "syntax": {
    "version": "v755",
    "errorNamespace": "^(Z|Y|LCL_|TY_|/.+/)"
  },
  "rules": {
    "parser_error": true,
    "unknown_types": false,
    "check_syntax": false,
    "obsolete_statement": {
      "exec": true,
      "exitOrCheck": false
    }
  }
}
